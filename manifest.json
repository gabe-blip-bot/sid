{
  "manifest_version": 3,
  "name": "Sidebar Sid",
  "version": "1.5.1",
  "description": "A lightweight browser context layer. Answer: what was I working on?",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Open Sidebar Sid"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
