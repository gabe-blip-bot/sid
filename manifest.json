{
  "manifest_version": 3,
  "name": "Sidebar Sid",
  "version": "1.39.0",
  "description": "A lightweight browser context layer. Answer: what was I working on?",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "action": {
    "default_title": "Open Sidebar Sid"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Period",
        "mac": "Command+Shift+Period"
      },
      "description": "Toggle the Sidebar Sid side panel"
    },
    "reload-extension": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Reload the extension (re-reads files from disk)"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
